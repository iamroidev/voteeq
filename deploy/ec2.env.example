# Copy to /opt/voteeq/backend/.env on EC2 — never commit real values
NODE_ENV=production
PORT=5000

TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

JWT_SECRET=change-me-long-random
ADMIN_USERNAME=
ADMIN_PASSWORD=

CORS_ORIGIN=https://voteeq.online,https://www.voteeq.online,https://voteeq.vercel.app
FRONTEND_URL=https://www.voteeq.online

PAYSTACK_SECRET_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Voteeq <receipts@voteeq.online>

SEED_ASCES_AWARDS=true
TICKETS_ENABLED=false
